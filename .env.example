# --- Public site URL (used for SEO / OpenGraph metadata) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- FixItNow API base URL ---
# The web app talks to the API for everything: auth, categories, businesses,
# bookings, reviews. In dev this should match `apps/api` (default :4000).
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Sentry (optional) ---
# Leave blank to disable Sentry. When set, errors are reported on the client.
NEXT_PUBLIC_SENTRY_DSN=""
# Server-only DSN (optional, falls back to NEXT_PUBLIC_SENTRY_DSN).
SENTRY_DSN=""
# Required only at build time if you want Sentry's source-map upload.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""
