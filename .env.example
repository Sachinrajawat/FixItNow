# --- Public site URL (used for SEO / OpenGraph metadata) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Hygraph (CMS) ---
# Sign up at https://hygraph.com and create a project.
# Copy the project ID portion of your endpoint URL here.
NEXT_PUBLIC_MASTER_URL_KEY="your_hygraph_project_id"

# --- Descope (Authentication) ---
# Sign up at https://www.descope.com and create an OIDC application.
DESCOPE_CLIENT_ID="your_descope_client_id"
DESCOPE_CLIENT_SECRET="your_descope_client_secret"

# --- NextAuth ---
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="replace_me_with_a_long_random_string"
NEXTAUTH_URL="http://localhost:3000"

# --- Sentry (optional) ---
# Leave blank to disable Sentry. When set, errors are reported on the client.
NEXT_PUBLIC_SENTRY_DSN=""
# Server-only DSN (optional, falls back to NEXT_PUBLIC_SENTRY_DSN).
SENTRY_DSN=""
# Required only at build time if you want Sentry's source-map upload.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""
