# Vercel (and some other hosted CI providers) set NODE_ENV=production before
# `npm install` runs, which makes npm skip devDependencies entirely. For a
# Next.js + monorepo build that needs tailwindcss / postcss / autoprefixer /
# @types/* at *build time*, that breaks the build with confusing
# "Module not found: Can't resolve '@/...'" errors well after CSS processing
# silently failed.
#
# This setting forces `npm install` to always install devDependencies,
# matching the behaviour of a developer's laptop and Render's deps stage.
production=false
