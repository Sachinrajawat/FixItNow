NODE_ENV="development"
PORT="4000"

# Mongo
MONGO_URI="mongodb://localhost:27017/fixitnow"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth (must each be at least 32 chars)
JWT_ACCESS_SECRET="change_me_to_a_long_random_string_at_least_32_chars"
JWT_REFRESH_SECRET="change_me_to_a_DIFFERENT_long_random_string_32_chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS — comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# Logging
LOG_LEVEL="info"
