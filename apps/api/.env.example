NODE_ENV="development"
PORT="4000"

# Mongo
# When you run `npm run dev:api` from the host AND start Mongo via
# `docker compose up mongo`, the docker container exposes Mongo on host
# port 27018 (see docker-compose.yml). Inside the docker network the API
# would talk to it as mongodb://mongo:27017 instead.
MONGO_URI="mongodb://localhost:27018/fixitnow"

# Redis
# Same story — host port 6380 to avoid colliding with a local / tunnelled Redis.
REDIS_URL="redis://localhost:6380"

# Auth (must each be at least 32 chars)
JWT_ACCESS_SECRET="change_me_to_a_long_random_string_at_least_32_chars"
JWT_REFRESH_SECRET="change_me_to_a_DIFFERENT_long_random_string_32_chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS — comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# Logging
LOG_LEVEL="info"
