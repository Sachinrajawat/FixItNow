{
  "name": "@fixitnow/api",
  "version": "0.1.0",
  "private": true,
  "description": "FixItNow REST API (Express + TypeScript + MongoDB + Redis).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --passWithNoTests --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --passWithNoTests --forceExit",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.1",
    "@fixitnow/types": "*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "pino": "^9.3.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  }
}
