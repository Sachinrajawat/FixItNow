{
  "name": "fixitnow",
  "version": "0.1.0",
  "private": true,
  "description": "FixItNow - a full-stack home services marketplace where users can discover, book and review local service providers.",
  "author": "Sachin Rajawat <sachinrajawat835@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "echo \"Typecheck will be enabled in Phase 1 (TypeScript migration)\" && exit 0",
    "test": "echo \"Tests will be added in Phase 1\" && exit 0",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker build -f Dockerfile -t fixitnow:latest . && docker run -p 3000:3000 --env-file .env fixitnow:latest"
  },
  "dependencies": {
    "@descope/nextjs-sdk": "^0.0.7",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "lucide-react": "^0.367.0",
    "moment": "^2.30.1",
    "next": "14.1.4",
    "next-auth": "^4.24.7",
    "next-themes": "^0.3.0",
    "react": "^18",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18",
    "sonner": "^1.4.41",
    "tailwind-merge": "^2.2.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.1.4",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "tailwindcss": "^3.3.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
